<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNewsManagementSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NguyenNguyenNguRazorPages.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-soft sticky-top py-3 mb-4">
            <div class="container">
                <a class="navbar-brand text-primary d-flex align-items-center gap-2" asp-page="/Index">
                    <i class="bi bi-newspaper fs-4"></i>
                    <span class="fw-extrabold text-uppercase" style="letter-spacing: 0.5px;">FUNewsManagementSystem</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold px-3" asp-page="/Index"><i class="bi bi-house-door-fill text-muted me-1"></i> Trang Chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold px-3" asp-page="/News/Index"><i class="bi bi-megaphone-fill text-muted me-1"></i> Đọc Tin Tức</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-2 mt-2 mt-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-2 text-secondary d-flex align-items-center gap-2 bg-light px-3 py-2 rounded-premium border border-light" style="font-size: 0.9rem;">
                                <i class="bi bi-person-circle text-primary fs-5"></i>
                                <div>
                                    <span class="text-muted d-block small" style="font-size: 0.75rem;">Đã đăng nhập</span>
                                    <strong>@User.Identity.Name</strong> 
                                    <span class="badge bg-primary text-white ms-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </div>
                            </li>
                            <li class="nav-item">
                                <a href="/Logout" class="btn btn-danger btn-sm shadow-soft fw-bold d-flex align-items-center gap-1 text-white" style="color: #ffffff !important; border-color: #ff416c !important;">
                                    <i class="bi bi-box-arrow-right text-white" style="color: #ffffff !important;"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            @if (ViewContext.RouteData.Values["page"]?.ToString() != "/Login")
                            {
                                <li class="nav-item">
                                    <a href="/Login" class="btn btn-primary btn-sm shadow-soft fw-bold d-flex align-items-center gap-1">
                                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-3 shadow-soft" style="position: absolute; bottom: 0; width: 100%;">
        <div class="container text-center">
            &copy; 2026 - <span class="text-primary fw-bold">FUNewsManagementSystem</span> - <a asp-page="/Privacy" class="text-decoration-none text-muted">Chính sách bảo mật</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
