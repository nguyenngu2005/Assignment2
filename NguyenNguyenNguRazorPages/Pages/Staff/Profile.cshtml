@page
@model NguyenNguyenNguRazorPages.Pages.Staff.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center g-4">
        <!-- Personal Profile Form Card (Size 5 for layout distribution) -->
        <div class="col-lg-5">
            <div class="card border-0 rounded-card shadow-soft overflow-hidden h-100 bg-white">
                <div class="gradient-dark text-white p-4 text-center position-relative">
                    <i class="bi bi-person-badge display-3 opacity-75"></i>
                    <h4 class="fw-bold mt-2 mb-0">Hồ Sơ Cá Nhân</h4>
                    <p class="mb-0 text-white-50 small">Cập nhật mật khẩu và thông tin tài khoản của bạn</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-premium shadow-soft border-0 mb-3 px-3 py-2.5" role="alert" style="font-size: 0.9rem;">
                            <i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i>
                            @TempData["Message"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-premium shadow-soft border-0 mb-3 px-3 py-2.5" role="alert" style="font-size: 0.9rem;">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5 align-middle"></i>
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post">
                        <input type="hidden" asp-for="AccountProfile.AccountId" />
                        <input type="hidden" asp-for="AccountProfile.AccountRole" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;"><i class="bi bi-envelope-fill me-1 text-primary"></i> Email đăng nhập (Không được sửa)</label>
                            <input type="email" asp-for="AccountProfile.AccountEmail" class="form-control bg-light text-muted border-0" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;"><i class="bi bi-person-fill me-1 text-primary"></i> Họ và Tên</label>
                            <input type="text" asp-for="AccountProfile.AccountName" class="form-control" required placeholder="Nhập họ và tên cá nhân..." />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary" style="font-size: 0.85rem;"><i class="bi bi-shield-lock-fill me-1 text-primary"></i> Mật khẩu đăng nhập</label>
                            <input type="text" asp-for="AccountProfile.AccountPassword" class="form-control" required placeholder="Nhập mật khẩu mới..." />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success fw-bold py-2.5 shadow-soft border-0 gradient-success">
                                <i class="bi bi-save me-1"></i> Lưu thông tin cá nhân
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- News History List (Rendered for Staff, Size 7 for balance) -->
        @if (User.IsInRole("Staff"))
        {
            <div class="col-lg-7">
                <div class="card border-0 rounded-card shadow-soft overflow-hidden h-100 bg-white">
                    <div class="card-header bg-light border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-clock-history text-primary"></i> Lịch Sử Tin Tức Bạn Biên Tập</h5>
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1.5 fw-bold">Tổng số: @Model.MyNewsArticles.Count</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.MyNewsArticles != null && Model.MyNewsArticles.Any())
                        {
                            <div class="table-responsive" style="max-height: 480px; overflow-y: auto;">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light sticky-top text-uppercase text-secondary" style="font-size: 0.8rem; letter-spacing: 0.5px; z-index: 1;">
                                        <tr>
                                            <th class="py-2.5 ps-4">Mã số</th>
                                            <th class="py-2.5">Tiêu đề tin</th>
                                            <th class="py-2.5">Chuyên mục</th>
                                            <th class="py-2.5 text-center">Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody class="border-top-0">
                                        @foreach (var article in Model.MyNewsArticles)
                                        {
                                            <tr>
                                                <td class="py-3 ps-4 fw-bold text-secondary">#@article.NewsArticleId</td>
                                                <td class="py-3 fw-bold text-dark text-truncate" style="max-width: 180px;">@article.NewsTitle</td>
                                                <td class="py-3 small"><span class="badge bg-light text-dark border">@(article.Category?.CategoryName ?? "N/A")</span></td>
                                                <td class="py-3 text-center">
                                                    @if (article.NewsStatus == true)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="font-size: 0.75rem;">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="font-size: 0.75rem;">Inactive</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 px-4 text-muted">
                                <i class="bi bi-card-list display-4 text-secondary opacity-50 mb-3 d-block"></i>
                                <p class="fw-bold mb-1">Chưa có bài viết biên tập!</p>
                                <p class="small text-muted mb-3">Bạn chưa đăng bất kỳ bản tin nào trên hệ thống.</p>
                                <a href="/Staff/NewsManagement" class="btn btn-sm btn-primary shadow-soft fw-bold"><i class="bi bi-plus-circle me-1"></i> Soạn thảo bài đầu tiên</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>